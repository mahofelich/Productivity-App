// ┌───────────────────────────────────────────────────────────────────────────┐
// │  SETUP: copy this file to "EmailConfig.Secrets.cs" (same folder) and fill  │
// │  in your IMAP details. EmailConfig.Secrets.cs is gitignored, so your mail  │
// │  credentials stay OUT of source control.                                   │
// │                                                                             │
// │  Common hosts:                                                              │
// │    Gmail     imap.gmail.com        port 993   (needs an App Password:      │
// │              Google Account -> Security -> 2-Step Verification -> App      │
// │              passwords. Your normal password will NOT work.)               │
// │    Outlook   outlook.office365.com port 993                                │
// │    Fastmail  imap.fastmail.com     port 993   (app password required)      │
// │    iCloud    imap.mail.me.com      port 993   (app-specific password)      │
// └───────────────────────────────────────────────────────────────────────────┘
namespace ProductivityHub.Services;

public static partial class EmailConfig
{
    static partial void LoadSecrets(
        ref string host, ref int port, ref bool useStartTls,
        ref string username, ref string password,
        ref string folder, ref int fetchCount)
    {
        host        = "imap.YOUR-PROVIDER.com";
        port        = 993;          // 993 = SSL (default). 143 + useStartTls=true for STARTTLS.
        useStartTls = false;
        username    = "you@example.com";
        password    = "CHANGE-ME";  // use an app password, not your account password
        folder      = "INBOX";      // mailbox to read
        fetchCount  = 25;           // how many recent messages to show
    }
}
