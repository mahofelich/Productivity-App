// ┌───────────────────────────────────────────────────────────────────────────┐
// │  SETUP: copy this file to "DriveSyncConfig.Secrets.cs" (same folder) and   │
// │  fill in the three values from your Google service account JSON key.       │
// │  DriveSyncConfig.Secrets.cs is gitignored so credentials stay out of git.  │
// │                                                                             │
// │  Full setup steps are in DriveSyncConfig.cs and the README:                 │
// │   1. Google Cloud project → enable the Drive API                            │
// │   2. Create a service account → download a JSON key                         │
// │   3. In your own Google Drive, make a folder and SHARE it (Editor) with     │
// │      the service account's email address                                    │
// │   4. Paste values below, rebuild. Every device you build syncs together.    │
// └───────────────────────────────────────────────────────────────────────────┘
namespace ProductivityHub.Services;

public static partial class DriveSyncConfig
{
    static partial void LoadSecrets(
        ref string serviceAccountEmail, ref string privateKeyPem,
        ref string folderId, ref string fileName)
    {
        // "client_email" from the JSON key
        serviceAccountEmail = "your-sa@your-project.iam.gserviceaccount.com";

        // "private_key" from the JSON key — paste the WHOLE value, keeping the
        // \n escapes exactly as they appear in the JSON file:
        privateKeyPem = "-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBg...\n-----END PRIVATE KEY-----\n";

        // Folder id from the folder's URL: drive.google.com/drive/folders/<THIS>
        folderId = "PASTE-FOLDER-ID";

        // Backup file name inside the folder (fine to leave as is)
        fileName = "productivityhub-backup.db3";
    }
}
