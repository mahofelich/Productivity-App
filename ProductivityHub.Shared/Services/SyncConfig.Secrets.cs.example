// ┌─────────────────────────────────────────────────────────────────────────┐
// │  SETUP: copy this file to "SyncConfig.Secrets.cs" (same folder) and fill  │
// │  in your three values. SyncConfig.Secrets.cs is gitignored, so your keys  │
// │  and RowId stay OUT of source control.                                    │
// └─────────────────────────────────────────────────────────────────────────┘
namespace ProductivityHub.Services;

public static partial class SyncConfig
{
    static partial void LoadSecrets(ref string url, ref string key, ref string rowId)
    {
        url   = "https://YOUR-PROJECT.supabase.co"; // Settings -> Data API -> Project URL
        key   = "sb_publishable_xxx";               // Settings -> API Keys -> Publishable (or legacy anon)
        rowId = "pick-a-long-random-string";        // your private sync id - same on every device
    }
}
