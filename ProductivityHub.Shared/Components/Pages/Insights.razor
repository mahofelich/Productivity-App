@page "/insights"
@inject IDbContextFactory<AppDbContext> Dbf
@inject IInsightService InsightSvc
@inject IGamificationService Gamify

<h1 style="font-size:1.6rem"><i class="fa-solid fa-wand-magic-sparkles"></i> AI Insights</h1>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card-ph">
            <h3>What to focus on</h3>
            @if (_insights.Count == 0)
            {
                <p class="muted mb-0">Gathering insights…</p>
            }
            else
            {
                @foreach (var i in _insights)
                {
                    <div class="insight-row"><i class="fa-solid fa-lightbulb"></i><span>@i</span></div>
                }
            }
            <p class="small muted mt-2 mb-0">Rule-based engine — swap <code>InsightService</code> for an LLM call to upgrade.</p>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card-ph">
            <h3>Level @_level</h3>
            <div class="d-flex justify-content-between small muted">
                <span>@_xpThisLevel / @_xpNeeded XP</span>
                <span>@_xp total</span>
            </div>
            <div class="progress-thin mt-1"><div style="width:@_progress%; background:var(--accent)"></div></div>
        </div>
    </div>

    <div class="col-12">
        <div class="card-ph">
            <h3>Achievements</h3>
            <div class="badge-grid">
                @foreach (var a in _earned)
                {
                    <div class="badge-card earned">
                        <i class="fa-solid @a.Icon"></i>
                        <div class="badge-name">@a.Name</div>
                        <div class="small muted">@a.Description</div>
                    </div>
                }
                @foreach (var a in _locked)
                {
                    <div class="badge-card locked">
                        <i class="fa-solid @a.Icon"></i>
                        <div class="badge-name">@a.Name</div>
                        <div class="small muted">@a.Description</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<string> _insights = [];
    private int _level = 1, _xp, _xpThisLevel, _xpNeeded, _progress;
    private List<Achievement> _earned = [];
    private List<Achievement> _locked = [];

    protected override async Task OnInitializedAsync()
    {
        await Gamify.CheckAchievementsAsync(Local.UserId);
        _insights = await InsightSvc.FullInsightsAsync(Local.UserId);

        await using var db = await Dbf.CreateDbContextAsync();
        var user = await db.Users.FindAsync(Local.UserId);
        _level = user?.Level ?? 1;
        _xp = user?.Xp ?? 0;

        var prev = Gamify.XpForLevel(_level - 1);
        var next = Gamify.XpForLevel(_level);
        _xpThisLevel = _xp - prev;
        _xpNeeded = next - prev;
        _progress = _xpNeeded <= 0 ? 100 : Math.Clamp((int)Math.Round(100.0 * _xpThisLevel / _xpNeeded), 0, 100);

        var all = await db.Achievements.ToListAsync();
        var ownedIds = (await db.UserAchievements.Where(a => a.UserId == Local.UserId).Select(a => a.AchievementId).ToListAsync()).ToHashSet();
        _earned = all.Where(a => ownedIds.Contains(a.Id)).ToList();
        _locked = all.Where(a => !ownedIds.Contains(a.Id)).ToList();
    }
}
