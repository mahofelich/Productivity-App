@namespace ProductivityHub.Components.Layout
@inherits LayoutComponentBase
@implements IDisposable
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IDbContextFactory<AppDbContext> Dbf

<div class="app-shell">
    <aside class="sidebar @(_open ? "open" : "")">
        <div class="brand"><i class="fa-solid fa-bolt"></i> ProductivityHub</div>
        <nav @onclick="Close">
            <NavLink href="" Match="NavLinkMatch.All"><i class="fa-solid fa-gauge-high"></i><span>Dashboard</span></NavLink>
            <NavLink href="calendar"><i class="fa-solid fa-calendar-days"></i><span>Calendar</span></NavLink>
            <NavLink href="tasks"><i class="fa-solid fa-list-check"></i><span>Tasks</span></NavLink>
            <NavLink href="notes"><i class="fa-solid fa-note-sticky"></i><span>Notes</span></NavLink>
            <NavLink href="email"><i class="fa-solid fa-envelope"></i><span>Email</span></NavLink>
            <NavLink href="journal"><i class="fa-solid fa-book"></i><span>Journal</span></NavLink>
            <NavLink href="health"><i class="fa-solid fa-heart-pulse"></i><span>Health</span></NavLink>
            <NavLink href="habits"><i class="fa-solid fa-repeat"></i><span>Habits</span></NavLink>
            <NavLink href="analytics"><i class="fa-solid fa-chart-line"></i><span>Analytics</span></NavLink>
            <NavLink href="insights"><i class="fa-solid fa-wand-magic-sparkles"></i><span>AI Insights</span></NavLink>
            <NavLink href="recommendations"><i class="fa-solid fa-lightbulb"></i><span>For You</span></NavLink>
        </nav>
        <div class="sidebar-footer">
            <span class="topbar-note"><i class="fa-solid fa-mobile-screen"></i> Local · works offline</span>
        </div>
    </aside>

    @if (_open)
    {
        <div class="scrim" @onclick="Close"></div>
    }

    <div class="main-area">
        <div class="topbar">
            <button class="hamburger" @onclick="Toggle"><i class="fa-solid fa-bars"></i></button>
            <div class="topbar-right">
                <div class="popdown">
                    <button class="icon-btn" title="Theme" @onclick="ToggleThemeMenu">
                        <i class="fa-solid fa-palette"></i>
                    </button>
                    @if (_themeMenuOpen)
                    {
                        <div class="popdown-backdrop" @onclick="CloseThemeMenu"></div>
                        <div class="popdown-panel">
                            @foreach (var t in ThemeCatalog.All)
                            {
                                <button class="popdown-item @(t.Key == _theme ? "active" : "")"
                                        @onclick="() => SetTheme(t.Key)">
                                    <span class="swatch" style="background:@t.Accent"></span> @t.Name
                                </button>
                            }
                        </div>
                    }
                </div>
                <button class="profile-btn" title="Settings" @onclick="GoSettings">@_initial</button>
            </div>
        </div>
        <main class="content">
            @Body
        </main>
    </div>
</div>

@code {
    private bool _open;
    private bool _themeMenuOpen;
    private string _theme = "dark";
    private string _initial = "•";

    private void Toggle() => _open = !_open;
    private void Close() => _open = false;

    private void ToggleThemeMenu() => _themeMenuOpen = !_themeMenuOpen;
    private void CloseThemeMenu() => _themeMenuOpen = false;

    private void GoSettings() { _themeMenuOpen = false; Nav.NavigateTo("settings"); }

    protected override async Task OnInitializedAsync()
    {
        AppEvents.UserChanged += OnUserChanged;
        await LoadInitialAsync();
    }

    private async Task LoadInitialAsync()
    {
        await using var db = await Dbf.CreateDbContextAsync();
        var user = await db.Users.FindAsync(Local.UserId);
        var name = user?.DisplayName?.Trim();
        _initial = string.IsNullOrEmpty(name) ? "•" : char.ToUpperInvariant(name[0]).ToString();
    }

    private void OnUserChanged() => _ = InvokeAsync(async () => { await LoadInitialAsync(); StateHasChanged(); });

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _theme = await JS.InvokeAsync<string>("phTheme.init");
            StateHasChanged();
        }
    }

    private async Task SetTheme(string key)
    {
        _theme = key;
        _themeMenuOpen = false;
        await JS.InvokeVoidAsync("phTheme.set", key);
    }

    public void Dispose() => AppEvents.UserChanged -= OnUserChanged;
}
