@namespace ProductivityHub.Components.Layout
@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="app-shell">
    <aside class="sidebar @(_open ? "open" : "")">
        <div class="brand"><i class="fa-solid fa-bolt"></i> ProductivityHub</div>
        <nav @onclick="Close">
            <NavLink href="" Match="NavLinkMatch.All"><i class="fa-solid fa-gauge-high"></i><span>Dashboard</span></NavLink>
            <NavLink href="calendar"><i class="fa-solid fa-calendar-days"></i><span>Calendar</span></NavLink>
            <NavLink href="tasks"><i class="fa-solid fa-list-check"></i><span>Tasks</span></NavLink>
            <NavLink href="notes"><i class="fa-solid fa-note-sticky"></i><span>Notes</span></NavLink>
            <NavLink href="journal"><i class="fa-solid fa-book"></i><span>Journal</span></NavLink>
            <NavLink href="health"><i class="fa-solid fa-heart-pulse"></i><span>Health</span></NavLink>
            <NavLink href="habits"><i class="fa-solid fa-repeat"></i><span>Habits</span></NavLink>
            <NavLink href="analytics"><i class="fa-solid fa-chart-line"></i><span>Analytics</span></NavLink>
            <NavLink href="insights"><i class="fa-solid fa-wand-magic-sparkles"></i><span>AI Insights</span></NavLink>
            <NavLink href="recommendations"><i class="fa-solid fa-lightbulb"></i><span>For You</span></NavLink>
        </nav>
        <div class="sidebar-footer">
            <button class="theme-toggle" @onclick="ToggleTheme">
                <i class="fa-solid fa-circle-half-stroke"></i> Theme
            </button>
        </div>
    </aside>

    @if (_open)
    {
        <div class="scrim" @onclick="Close"></div>
    }

    <div class="main-area">
        <div class="topbar">
            <button class="hamburger" @onclick="Toggle"><i class="fa-solid fa-bars"></i></button>
            <div class="topbar-right"><i class="fa-solid fa-mobile-screen"></i> Local · works offline</div>
        </div>
        <main class="content">
            @Body
        </main>
    </div>
</div>

@code {
    private bool _open;

    private void Toggle() => _open = !_open;
    private void Close() => _open = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("phTheme.init");
    }

    private async Task ToggleTheme() => await JS.InvokeVoidAsync("phTheme.toggle");
}
