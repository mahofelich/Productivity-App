@page "/"
@inject IDashboardService Dashboard
@inject IDbContextFactory<AppDbContext> Dbf
@inject IGamificationService Gamify
@inject NavigationManager Nav
@implements IDisposable

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
        <h1 style="font-size:1.6rem;margin:0">Hi @(_name) 👋</h1>
        <div class="muted">@DateTime.Now.ToString("dddd, MMMM d")</div>
    </div>
    <div class="text-end">
        <div style="font-family:var(--font-display);font-size:1.6rem">@_now.ToString("HH:mm:ss")</div>
        <div class="muted small">Level @(_data?.Level ?? 1) · @(_data?.Xp ?? 0) XP</div>
    </div>
</div>

<div class="quickadd mb-3">
    <a href="tasks"><i class="fa-solid fa-plus"></i> Task</a>
    <a href="calendar"><i class="fa-solid fa-calendar-plus"></i> Event</a>
    <a href="notes"><i class="fa-solid fa-pen"></i> Note</a>
    <a href="journal"><i class="fa-solid fa-book"></i> Journal</a>
    <button @onclick="() => AddWater(250)"><i class="fa-solid fa-droplet"></i> +250ml</button>
</div>

@if (_data is null)
{
    <div class="card-ph">Loading…</div>
}
else
{
    var d = _data;
    var circ = 301.59;
    var off = circ * (1 - d.ProductivityScore / 100.0);
    var waterPct = Math.Min(100, d.WaterMlToday * 100 / Math.Max(1, d.WaterGoalMl));
    var calPct = Math.Min(100, d.CaloriesToday * 100 / Math.Max(1, d.CalorieGoal));

    <div class="widget-grid">
        <div class="card-ph widget">
            <h3><i class="fa-solid fa-gauge-high"></i> Productivity score</h3>
            <div class="ring">
                <svg width="110" height="110" viewBox="0 0 110 110">
                    <circle class="ring-bg" cx="55" cy="55" r="48" fill="none" stroke-width="10" />
                    <circle class="ring-val" cx="55" cy="55" r="48" fill="none" stroke-width="10"
                            stroke-dasharray="@circ.ToString("0.##")" stroke-dashoffset="@off.ToString("0.##")" />
                </svg>
                <div class="ring-label"><b>@d.ProductivityScore</b><span class="muted small">/ 100</span></div>
            </div>
        </div>

        <div class="card-ph widget text-center">
            <h3 class="justify-content-center"><i class="fa-solid fa-droplet" style="color:var(--water)"></i> Water</h3>
            <div class="bottle"><div class="fill" style="height:@waterPct%"></div></div>
            <p class="mt-2 mb-1"><b>@d.WaterMlToday</b> <span class="muted">/ @d.WaterGoalMl ml</span></p>
            <div class="d-flex gap-2 justify-content-center flex-wrap">
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => AddWater(150)">+150</button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => AddWater(250)">+250</button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => AddWater(500)">+500</button>
            </div>
        </div>

        <div class="card-ph widget">
            <h3><i class="fa-solid fa-fire" style="color:var(--warn)"></i> Calories</h3>
            <p class="mb-1"><b>@d.CaloriesToday</b> <span class="muted">/ @d.CalorieGoal kcal</span></p>
            <div class="progress-thin"><div style="width:@calPct%; background:var(--warn)"></div></div>
            <a href="health" class="small d-inline-block mt-2">Log food →</a>
        </div>

        <div class="card-ph widget">
            <h3><i class="fa-solid fa-list-check"></i> Due today</h3>
            @if (d.TasksDueToday.Count == 0)
            {
                <p class="muted mb-0">Nothing due. Enjoy the breathing room.</p>
            }
            else
            {
                <ul class="list-unstyled mb-0">
                    @foreach (var t in d.TasksDueToday)
                    {
                        <li class="d-flex justify-content-between py-1">
                            <span>@t.Title</span>
                            <span class="pill p-@t.Priority">@t.Priority</span>
                        </li>
                    }
                </ul>
            }
        </div>

        <div class="card-ph widget">
            <h3><i class="fa-solid fa-calendar-day"></i> Upcoming</h3>
            @if (d.UpcomingEvents.Count == 0)
            {
                <p class="muted mb-0">No events in the next 48 hours.</p>
            }
            else
            {
                <ul class="list-unstyled mb-0">
                    @foreach (var e in d.UpcomingEvents)
                    {
                        <li class="py-1"><span class="small">@e.StartTime.ToString("ddd HH:mm") · @e.Title</span></li>
                    }
                </ul>
            }
        </div>

        <div class="card-ph widget">
            <h3><i class="fa-solid fa-repeat"></i> Today's habits</h3>
            <p class="mb-1"><b>@d.HabitsDoneToday</b> / @d.HabitsTotal done</p>
            <div class="progress-thin"><div style="width:@(d.HabitsTotal == 0 ? 0 : d.HabitsDoneToday * 100 / d.HabitsTotal)%; background:var(--accent)"></div></div>
            <p class="small muted mt-2 mb-0"><i class="fa-solid fa-fire streak-flame"></i> @d.JournalStreak-day journal streak</p>
        </div>

        <div class="card-ph widget">
            <h3><i class="fa-solid fa-wand-magic-sparkles"></i> Daily insight</h3>
            <p class="mb-0">@d.Insight</p>
        </div>

        <div class="card-ph widget">
            <h3><i class="fa-solid fa-quote-left"></i> Quote</h3>
            <p class="mb-0 fst-italic">@d.Quote</p>
        </div>
    </div>
}

@code {
    private DashboardData? _data;
    private string _name = "there";
    private DateTime _now = DateTime.Now;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await Dbf.CreateDbContextAsync();
        var user = await db.Users.FindAsync(Local.UserId);
        if (user is not null && !string.IsNullOrWhiteSpace(user.DisplayName)) _name = user.DisplayName;

        _data = await Dashboard.BuildAsync(Local.UserId);

        _timer = new System.Threading.Timer(_ =>
        {
            _now = DateTime.Now;
            InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    private async Task AddWater(int ml)
    {
        await using var db = await Dbf.CreateDbContextAsync();
        db.WaterEntries.Add(new WaterEntry { UserId = Local.UserId, AmountMl = ml });
        await db.SaveChangesAsync();
        await Gamify.AwardXpAsync(Local.UserId, 5);
        await Gamify.CheckAchievementsAsync(Local.UserId);
        _data = await Dashboard.BuildAsync(Local.UserId);
    }

    public void Dispose() => _timer?.Dispose();
}
